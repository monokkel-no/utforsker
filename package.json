{
  "name": "monokkel",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "check": "run-p -c check:*",
    "check:biome": "biome check",
    "check:knip": "knip",
    "check:workspaces": "pnpm -r check",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "dev": "pnpm -r --parallel dev",
    "format": "biome format --write .",
    "serve": "pnpm -r --parallel serve"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.0",
    "@types/node": "catalog:",
    "knip": "^5.66.3",
    "typescript": "catalog:",
    "npm-run-all": "catalog:"
  },
  "engines": {
    "node": ">=25.0.0",
    "pnpm": ">=10.18.2"
  },
  "packageManager": "pnpm@10.18.2"
}
